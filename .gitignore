# General
.DS_Store
.idea
.vscode
*.log
*.swp
*.swo

# Node
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
# Keep package-lock.json if you want to lock versions, usually recommended to keep it. 
# But some prefer to ignore it if using yarn. I will keep it commented out to NOT ignore it by default.

# Expo / React Native
.expo/
dist/
web-build/
*.jks
*.p12
*.key
*.mobileprovision

# Android
android/
# If you ejected or have native code, you might want to keep android/ but ignore build folders.
# Since this uses Expo Prebuild or is a Managed workflow generally, we might want to ignore generated android folder 
# unless you specifically ejected. For standard Expo, 'android/' and 'ios/' are generated.
# If you want to track native changes, comment out android/ and ios/
# android/
# ios/
# But standard Expo managed workflow usually ignores them:
/.open-graph-image.png
/.expo
/node_modules

# Native builds (if you tracking android/ios folders)
android/app/build/
android/.gradle/
ios/Pods/
ios/build/

# Supabase / Backend Environment
backend/supabase/.branches
backend/supabase/config.toml
# Do NOT ignore migrations usually.
# Ignore local config generated by CLI if any
backend/.env
backend/.env.local

# Frontend Environment
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
*.env
*.env.*

# TypeScript
*.tsbuildinfo
